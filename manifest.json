{
  "manifest_version": 3,
  "name": "人民币大写转换器",
  "version": "2.0.2",
  "description": "将小写数字金额快速转换为中文大写人民币写法，支持多币种、右键菜单、历史记录、批量转换、千分位格式化",
  "author": "RMB Converter contributors",
  "homepage_url": "https://github.com/dodevnet/rmb-converter-extension",
  "minimum_chrome_version": "88",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "人民币大写转换器"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["clipboardWrite", "contextMenus", "notifications", "storage", "scripting"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "打开人民币大写转换器"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
